          "value": "\"transactions\".\"status\" in ('open', 'closed', 'reviewed')"
        },
        "transactions_direction_check": {
          "name": "transactions_direction_check",
          "value": "\"transactions\".\"direction\" in ('long', 'short')"
        },
        "transactions_outcome_check": {
          "name": "transactions_outcome_check",
          "value": "\"transactions\".\"outcome\" in ('win', 'loss', 'breakeven')"
        },
        "transactions_market_cycle_check": {
          "name": "transactions_market_cycle_check",
          "value": "\"transactions\".\"marketCycle\" is null or \"transactions\".\"marketCycle\" in ('Trading Range', 'Upward Tight Channel', 'Downward Tight Channel', 'Upward Channel', 'Downward Channel', 'Upward Trend', 'Downward Trend')"
        },
        "transactions_transaction_type_check": {
          "name": "transactions_transaction_type_check",
          "value": "\"transactions\".\"transactionType\" is null or \"transactions\".\"transactionType\" in ('Trend', 'Reversal')"
